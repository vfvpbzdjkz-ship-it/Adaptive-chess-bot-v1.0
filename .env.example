# Copy this to .env for local development.
# On Railway, set these in the service's Variables dashboard — never commit real values.

# Required
LICHESS_TOKEN=your_lichess_api_token_here

# Optional overrides (all have sensible defaults)
# HARDWARE_PROFILE=small          # small | medium | large  (small = 5x64 net, right for Railway CPU)
# MODE=auto                       # auto | play | train
# MATCHMAKER_ENABLED=true         # challenge other bots when idle
# SEED_GAMES=5000                 # reduce for faster first boot (default 5000 in cloud mode)
# SEED_TRAIN_STEPS=1000           # training steps on seed data
# ACCEPT_RATED=true
# ACCEPT_CASUAL=true
# MAX_CONCURRENT_GAMES=1
# CHAT_ENABLED=true
# WINNER_IMITATION=true
